{
  "name": "2025-hello-typescript-node",
  "type": "module",
  "version": "1.0.0",
  "description": "Basic scaffolding for a TypeScript Node.js project",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10"
  },
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "scripts": {
    "start": "node ./dist/index.js",
    "build": "node ./esbuild.config.mjs",
    "dev": "tsx watch ./src/index.ts",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "lint": "eslint .",
    "prod": "node ./dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "node.js",
    "express",
    "typescript",
    "esbuild"
  ],
  "author": "Richard Morgan",
  "license": "0BSD",
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "esbuild": "^0.27.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
